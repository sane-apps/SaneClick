# SaneProcess compliance manifest
name: SaneClick
type: macos_app
scheme: SaneClick
project: SaneClick.xcodeproj
bundle_id: com.saneclick.SaneClick

build:
  xcodegen: true

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.saneclick.com
  site_host: saneclick.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "14.0"
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "800 400"
    app_icon_pos: "200 185"
    drop_pos: "600 185"

appstore:
  enabled: true
  app_id: "6759330868"
  product_id: "com.saneclick.app.pro.unlock"
  scheme: SaneClick-AppStore
  configuration: Release-AppStore
  platforms: [macos]
  category: public.app-category.productivity
  age_rating: "4+"
  privacy_policy_url: "https://saneclick.com/privacy"
  support_url: "https://saneclick.com/support"
  marketing_url: "https://saneclick.com"
  metadata:
    macos:
      subtitle: "Finder Right-Click Tools"
      promotional_text: "Add 50+ Finder right-click actions in seconds. Automate file tasks, run scripts, and keep your workflow inside Finder."
      description: >-
        SaneClick upgrades Finder with 50+ ready-to-use right-click actions so you can move faster without leaving your file workflow.
        Automate repetitive tasks, run custom scripts, and show only actions that match selected files.
        Everything runs locally on your Mac with no tracking or cloud dependency.
      keywords: "finder,right click,automation,scripts,context menu,productivity,file tools,mac utility"
      whats_new: "Improved script reliability, smoother action filtering, and faster Finder extension responsiveness."
      marketing_url: "https://saneclick.com"
  review_notes: "SaneClick runs user-created automation scripts for Finder workflow and productivity actions. Some scripts use AppleScript via osascript (for example Finder actions and display notifications), so macOS may request Automation/Apple Events permission when those scripts target another app. Core file actions continue to work without Automation permission."
  accessibility_declarations:
    publish: true
    mac:
      supports_dark_interface: true
  screenshots:
    macos: docs/screenshots/*.png
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"
  entitlements: SaneClick/SaneClick-AppStore.entitlements
  strip_frameworks:
    - Sparkle.framework

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

website: true
website_domain: saneclick.com
