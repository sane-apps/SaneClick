  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "800 400"
    app_icon_pos: "200 185"
    drop_pos: "600 185"

appstore:
  enabled: true
  # App Store lane is ACTIVE for the owner-authorized 1.3.0 submission (revived 2026-06-29).
  # The direct-download channel remains live in parallel; this lane handles the Mac App Store submission only.
  # Compliance verified: the #if APP_STORE build is StoreKit IAP only (com.saneclick.app.pro.actions.v4),
  # with no crypto / external-unlock / license-key / Sparkle paths. Metadata, reviewer notes, What's New,
  # and the IAP block below are submission-ready. With enabled: true, verify/preflight run App Store
  # readiness checks (screenshots etc.); appstore_submit performs the build/sign/upload/submit-for-review.
  app_id: "6759330868"
  product_id: "com.saneclick.app.pro.actions.v4"
  scheme: SaneClick-AppStore
  configuration: Release-AppStore
  platforms: [macos]
  category: public.app-category.productivity
  age_rating: "4+"
  privacy_policy_url: "https://saneclick.com/privacy"
  support_url: "https://saneclick.com/support"
  marketing_url: "https://saneclick.com"
  metadata:
    macos:
      subtitle: "Right-Click File Tools"
      promotional_text: "Add native Finder actions to the folders you choose. Free includes 13 core actions; Pro adds OCR, PDF tools, image conversion and resizing, batch rename, hashing, and more built-in file tools."
      description: >-
        Add native right-click actions to the folders you choose in Finder.

        SaneClick keeps your Finder context menu focused by only showing actions inside the folders you monitor. Copy paths, create text files, reveal items, rename in batches, hash files, and work faster without leaving Finder.

        Free includes:
        • 13 built-in Finder actions
        • Monitored folders
        • Finder Sync actions inside those selected folders

        Pro unlock adds:
        • 24 more built-in Finder actions
        • OCR text recognition and PDF tools
        • Image conversion, resizing, and thumbnails
        • Batch rename and advanced file and folder tools
        • MD5 and SHA-256 hashing
        • Restore purchases across your Macs

        Everything runs locally on your Mac.
      keywords: "context menu,folders,batch rename,hash,copy path,terminal,file info,duplicate,productivity"
      whats_new: "A big update. Copy text out of any image, screenshot, or scan. Turn images into a PDF or a PDF into images. Convert, resize, rotate, and clean up photos, with results saved as a new file. Right-click actions are now grouped into folders, so everything is easy to find. Everything runs on your Mac."
      marketing_url: "https://saneclick.com"
  copyright: "2026 SaneApps"
  content_rights_declaration: "DOES_NOT_USE_THIRD_PARTY_CONTENT"
  export_compliance:
    uses_non_exempt_encryption: false
    exemption_reason: "SaneClick does not use encryption beyond Apple's operating-system-provided HTTPS for standard app distribution; no proprietary or non-exempt encryption is included."
  review_notes_by_platform:
    macos: >-
      SaneClick adds actions to the macOS Finder right-click menu; all actions run locally on the user's Mac and nothing is uploaded. After install, enable the SaneClick Finder extension in System Settings > Privacy & Security > Extensions > Added Extensions > Finder, then right-click a file or image in Finder (for example on the Desktop) and choose a SaneClick action.

      Business model: the basic tier is free. Free includes 13 actions. Pro is a one-time In-App Purchase (SaneClick Pro Access, $9.99) on the App Store that unlocks 24 more actions. There is no external checkout and no license key; everything is handled by App Store in-app purchase.

      To reach the optional Pro unlock, open SaneClick, go to Settings > License (the Unlock Pro / Restore Purchases path), or tap any locked Pro action (such as Copy Text from Image in the Images and Media submenu); either route shows the App Store in-app purchase prompt. Image, text, and PDF actions create a new file next to the original or copy to the clipboard. No subscription or account is required, and no login, sign-in, API key, password, or other credentials are needed to review the app — it works immediately after install. SaneClick uses no external provider or merchant accounts; any external accounts would be the user's own existing merchant accounts and do not unlock paid app features or digital content.
  iap:
    display_name: "SaneClick Pro Access"
    price_usd: 9.99
    description: "Unlock 24 more built-in file actions."
    review_note: "SaneClick Pro Access is a one-time non-consumable StoreKit purchase. It adds 24 more built-in native file actions, including OCR text recognition, PDF tools, image conversion and resizing, advanced hashing, and extra file and folder utilities. It does not unlock scripts, external checkout, or license keys."
  accessibility_declarations:
    publish: true
    mac:
      supports_dark_interface: true
  screenshots:
    macos: docs/screenshots/appstore-*.png
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"
  entitlements: SaneClick/SaneClick-AppStore.entitlements
  strip_frameworks:
    - Sparkle.framework

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

website: true
website_domain: saneclick.com
