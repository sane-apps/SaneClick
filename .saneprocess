# SaneProcess compliance manifest
name: SaneClick
type: macos_app
scheme: SaneClick
project: SaneClick.xcodeproj
bundle_id: com.saneclick.SaneClick

build:
  xcodegen: true

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.saneclick.com
  site_host: saneclick.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "14.0"
  reviewed_auto_reconcile_stashes:
    - stash_sha: "85401e38e0b484f64e6fbc84855446c2ebec692a"
      subject: "On main: auto-reconcile-20260508-215529-stephans-macbook-air"
      decision: recovered
      reason: "Reviewed 2026-05-09 against current release candidate. Customer-facing menu parity, Settings/License/About routing, App Group launch deferral, Finder extension launch arguments, mutual visibility repair, direct-download lane docs, update rows, and tests are present in current code; stale oversized General-tab/App Store screenshot parts are intentionally superseded."
    - stash_sha: "4420f3047f6257091127ea22ceb2d380e2b2a055"
      subject: "On main: auto-reconcile-20260430-215529-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. The only blocking file was a one-line docs/index.html deletion from older website copy; current website copy was later updated and verified against the direct-download channel."
    - stash_sha: "d63d5617fed535fd506013f0a1d3abd759a62faf"
      subject: "On main: auto-reconcile-20260429-215525-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. This older helper/test cleanup is superseded by current ContentView/ScriptLibraryView implementation and passing SaneClick tests; it would regress current shared category presentation work."
    - stash_sha: "174888a60992d2ed58cc2c04645408735a5fa2ff"
      subject: "On main: auto-reconcile-20260425-215529-stephans-macbook-air"
      decision: recovered
      reason: "Reviewed 2026-05-09. Privacy and website wording updates from Public Code to Transparent Code/source-available wording are already present in the current docs/site release candidate."
    - stash_sha: "75dc74a8322ee0dab07afab53441c81e40009127"
      subject: "On main: auto-reconcile-20260424-153503-stephans-macbook-air"
      decision: recovered
      reason: "Reviewed 2026-05-09. Architecture and development notes represented release/test guidance already carried forward in current docs and the active SaneProcess release guard."
    - stash_sha: "aeca764b633643fb8365f744ed48250358ca2e59"
      subject: "On main: auto-reconcile-20260418-055526-stephans-macbook-air"
      decision: deferred
      reason: "Reviewed 2026-05-09. This is App Store screenshot/storyboard and App Store lane collateral; SaneClick is direct-download-only for this release, so this work is not part of the current release candidate."
    - stash_sha: "279e615c23dcc45846078bd5700851b3034ec9e4"
      subject: "On main: auto-reconcile-20260411-055525-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. This old .claude/settings.json and .gitignore sync residue is superseded by current shared SaneProcess/Codex policy and should not affect the app release."
    - stash_sha: "be45a2c618d3b6811dab61511b8660e9f8320211"
      subject: "On main: auto-reconcile-20260410-215527-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. This old .gitignore residue is superseded by current canonical shared ignore rules."
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "800 400"
    app_icon_pos: "200 185"
    drop_pos: "600 185"

appstore:
  enabled: false
  # Current strategy: direct-download only.
  # Do not route the current full-featured build through App Store release automation.
  # App Store metadata below is retained only as dormant reference and is not an active lane.
  app_id: "6759330868"
  product_id: "com.saneclick.app.pro.actions.v4"
  scheme: SaneClick-AppStore
  configuration: Release-AppStore
  platforms: [macos]
  category: public.app-category.productivity
  age_rating: "4+"
  privacy_policy_url: "https://saneclick.com/privacy"
  support_url: "https://saneclick.com/support"
  marketing_url: "https://saneclick.com"
  metadata:
    macos:
      subtitle: "Right-Click File Tools"
      promotional_text: "Add native Finder actions to the folders you choose. Free includes 9 core actions; Pro adds batch rename, hashing, and more built-in file tools."
      description: >-
        Add native right-click actions to the folders you choose in Finder.

        SaneClick keeps your Finder context menu focused by only showing actions inside the folders you monitor. Copy paths, create text files, reveal items, rename in batches, hash files, and work faster without leaving Finder.

        Free includes:
        • 9 built-in Finder actions
        • Monitored folders
        • Finder Sync actions inside those selected folders

        Pro unlock adds:
        • 9 more built-in Finder actions
        • Batch rename and advanced file and folder tools
        • MD5 and SHA-256 hashing
        • Restore purchases across your Macs

        Everything runs locally on your Mac.
      keywords: "context menu,folders,batch rename,hash,copy path,terminal,file info,duplicate,productivity"
      whats_new: "Improves Finder extension reliability and makes the Pro upgrade path clearer in the App Store build."
      marketing_url: "https://saneclick.com"
  review_notes_by_platform:
    macos: >-
      SaneClick's current public strategy is direct download only. The Mac App Store lane is intentionally inactive for the current full-featured build and should not be submitted from this repo state. If an App Store-safe variant is revisited later, re-validate sandbox-safe behavior, pricing, StoreKit, and reviewer guidance from scratch.
  iap:
    display_name: "SaneClick Pro Access"
    price_usd: 9.99
    description: "Unlock 9 more built-in file actions."
    review_note: "SaneClick Pro Access is a one-time non-consumable StoreKit purchase. It adds 9 more built-in native file actions, including advanced hashing and extra file and folder utilities. It does not unlock scripts, external checkout, or license keys."
  accessibility_declarations:
    publish: true
    mac:
      supports_dark_interface: true
  screenshots:
    macos: docs/screenshots/*.png
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"
  entitlements: SaneClick/SaneClick-AppStore.entitlements
  strip_frameworks:
    - Sparkle.framework

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

website: true
website_domain: saneclick.com
