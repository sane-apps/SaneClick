# SaneProcess compliance manifest
name: SaneClick
type: macos_app
scheme: SaneClick
project: SaneClick.xcodeproj
bundle_id: com.saneclick.SaneClick

build:
  xcodegen: true

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.saneclick.com
  site_host: saneclick.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "14.0"
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "800 400"
    app_icon_pos: "200 185"
    drop_pos: "600 185"

appstore:
  enabled: true
  app_id: "6759330868"
  product_id: "com.saneclick.app.pro.unlock.v2"
  scheme: SaneClick-AppStore
  configuration: Release-AppStore
  platforms: [macos]
  category: public.app-category.productivity
  age_rating: "4+"
  privacy_policy_url: "https://saneclick.com/privacy"
  support_url: "https://saneclick.com/support"
  marketing_url: "https://saneclick.com"
  metadata:
    macos:
      subtitle: "Built-In File Actions"
      promotional_text: "Add built-in file actions to the folders you choose. Rename, organize, hash, and inspect files without leaving your workflow."
      description: >-
        SaneClick adds built-in right-click file actions to the folders you choose on your Mac.
        Use it to copy paths, rename files, organize folders, create text files, calculate hashes, clean up .DS_Store files, and handle other everyday file tasks without leaving your current folder workflow.
        Everything runs locally on your Mac. No tracking. No cloud service.
      keywords: "right click,file actions,file tools,rename,organize,clipboard,folders,productivity"
      whats_new: "App Store build now uses monitored folders with built-in native actions, plus smoother Finder extension reliability."
      marketing_url: "https://saneclick.com"
  review_notes: "SaneClick is a freemium App Store app. Basic is free in the App Store build. The free download includes 9 built-in native file actions, monitored folders, and the Finder Sync extension inside those selected folders. SaneClick Pro is an optional one-time non-consumable StoreKit in-app purchase that adds 9 more built-in native actions, including additional files-and-folders utilities and advanced hashing tools. There is no external checkout, website checkout, license key, or external payment flow in this build. The App Store build no longer runs user-created scripts. There are no Apple Events or automation entitlements in this build."
  iap:
    display_name: "SaneClick Pro Upgrade"
    description: "Unlock 9 more built-in file actions."
    review_note: "SaneClick Pro Unlock is a one-time non-consumable StoreKit purchase. It adds 9 more built-in native file actions, including advanced hashing and extra file and folder utilities. It does not unlock scripts, external checkout, or license keys."
  accessibility_declarations:
    publish: true
    mac:
      supports_dark_interface: true
  screenshots:
    macos: docs/screenshots/*.png
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"
  entitlements: SaneClick/SaneClick-AppStore.entitlements
  strip_frameworks:
    - Sparkle.framework

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

website: true
website_domain: saneclick.com
