    "saneclick.settings.help.restart_finder" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Finder neu starten, wenn die Erweiterung aktiviert ist, aber noch nicht läuft" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Restart Finder if the extension is enabled but not yet running" } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "Reinicia Finder si la extensión está activada pero aún no se está ejecutando" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Relancez Finder si l’extension est activée mais pas encore en cours d’exécution" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Riavvia Finder se l’estensione è attiva ma non è ancora in esecuzione" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "拡張機能が有効でもまだ実行されていない場合は Finder を再起動します" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "확장 프로그램이 켜져 있지만 아직 실행 중이 아니면 Finder를 다시 시작하세요" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Start Finder opnieuw als de extensie is ingeschakeld maar nog niet actief is" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Reinicie o Finder se a extensão estiver ativada, mas ainda não estiver em execução" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如果扩展已启用但尚未运行，请重新启动 Finder" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "如果延伸模組已啟用但尚未執行，請重新啟動 Finder" } }
      }
    },
    "saneclick.settings.hint.hidden_icons" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn du beide Symbole ausblendest, öffne SaneClick wieder über Programme." } },
